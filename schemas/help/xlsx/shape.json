{
  "$schema": "../_schema.json",
  "format": "xlsx",
  "element": "shape",
  "parent": "sheet",
  "operations": {
    "add": true,
    "set": true,
    "get": true,
    "query": true,
    "remove": true
  },
  "paths": {
    "positional": ["/SheetName/shape[N]"]
  },
  "note": "Aliases: textbox. Anchor: 'anchor=B2:F7' (cell range) or x/y/width/height in cell units. 'ref=B2' expands to a 1x1 cell rectangle.",
  "properties": {
    "shape": {
      "type": "string",
      "description": "shape geometry name (rect, ellipse, line, roundRect, etc.).",
      "add": true, "set": true, "get": true,
      "examples": ["--prop shape=rect"],
      "readback": "geometry preset name",
      "enforcement": "report"
    },
    "anchor": {
      "type": "string",
      "description": "cell range anchor (e.g. B2:F7). Overrides x/y/width/height.",
      "aliases": ["ref"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop anchor=B2:F7"],
      "readback": "resolved anchor",
      "enforcement": "report"
    },
    "text": {
      "type": "string",
      "add": true, "set": true, "get": true,
      "examples": ["--prop text=\"Note\""],
      "readback": "concatenated run text",
      "enforcement": "report"
    },
    "fill": {
      "type": "color",
      "add": true, "set": true, "get": true,
      "examples": ["--prop fill=#FFFF00"],
      "readback": "#-prefixed uppercase hex",
      "enforcement": "report"
    },
    "preset": {
      "type": "string",
      "description": "geometry preset name (rect, ellipse, roundRect, triangle, rightArrow, etc.). Unknown presets fall back to rect with a stderr warning.",
      "aliases": ["shape"],
      "add": true, "set": false, "get": false,
      "examples": ["--prop preset=ellipse"],
      "enforcement": "report"
    },
    "x": {
      "type": "string",
      "description": "anchor x position in cell units (or unit-qualified size).",
      "add": true, "set": false, "get": false,
      "examples": ["--prop x=2"],
      "enforcement": "report"
    },
    "y": {
      "type": "string",
      "description": "anchor y position in cell units (or unit-qualified size).",
      "add": true, "set": false, "get": false,
      "examples": ["--prop y=3"],
      "enforcement": "report"
    },
    "width": {
      "type": "string",
      "description": "shape width in cell units (or unit-qualified size like 6cm).",
      "add": true, "set": false, "get": false,
      "examples": ["--prop width=4", "--prop width=6cm"],
      "enforcement": "report"
    },
    "height": {
      "type": "string",
      "description": "shape height in cell units (or unit-qualified size).",
      "add": true, "set": false, "get": false,
      "examples": ["--prop height=3"],
      "enforcement": "report"
    }
  }
}
